# ---- Base de datos (PostgreSQL) ----
# Local: postgresql://postgres:postgres@localhost:5432/contahub
# Vercel Postgres / Neon / Supabase: usar la connection string con ?sslmode=require
DATABASE_URL=

# ---- Autenticacion ----
# Secreto para firmar los JWT de sesion (min 32 caracteres). Genera uno con: openssl rand -base64 32
AUTH_SECRET=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Almacenamiento de archivos ----
# Vercel Blob (recomendado en Vercel). Se obtiene en el dashboard de Vercel > Storage > Blob.
BLOB_READ_WRITE_TOKEN=

# ---- Correo ----
# Opcion A: Resend
RESEND_API_KEY=
# Opcion B: SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ContaHub <no-reply@contahub.com>"

# ---- Cron ----
# Secreto para proteger los endpoints /api/cron/* (Vercel envia Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
