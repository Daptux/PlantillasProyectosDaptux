# ===== Servidor =====
PORT=4000
NODE_ENV=development

# ===== Base de datos PostgreSQL =====
# Opción A (recomendada): una sola cadena de conexión.
#   Local:  postgres://postgres:postgres@localhost:5432/odontoadmin
#   Vercel/Neon/Supabase: usar la connection string con ?sslmode=require
DATABASE_URL=
# (En Vercel Postgres se inyecta automáticamente POSTGRES_URL; el backend también lo lee.)

# Opción B: variables discretas (solo si no usas DATABASE_URL) — para Postgres local.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=odontoadmin
DB_CONNECTION_LIMIT=5
# Forzar SSL con variables discretas: PGSSL=true

# ===== JWT =====
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ===== CORS (origen del frontend) =====
# En el despliegue todo-en-uno de Vercel, frontend y API comparten dominio,
# así que CORS no es necesario. En desarrollo separado, apunta al frontend.
CORS_ORIGIN=http://localhost:5173
