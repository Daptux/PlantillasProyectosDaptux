# ===========================================
#  OdontoAdmin Pro - Variables de entorno
#  Copia este archivo como .env y completa los valores
# ===========================================

# Servidor
PORT=4000
NODE_ENV=development

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=odontoadmin
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# CORS (origen del frontend)
CORS_ORIGIN=http://localhost:5173

# Carga de archivos (multer)
UPLOAD_DIR=uploads
