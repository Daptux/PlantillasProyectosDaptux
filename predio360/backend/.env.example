# Predio360 · Variables de entorno del backend
# Copia este archivo a .env.local (dev) y configúralas también en Vercel.

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # solo backend, NUNCA exponer en el frontend

# CORS (dominio del frontend en Vercel). Usa * solo en desarrollo.
CORS_ORIGIN=https://predio360.vercel.app

# OpenAI (módulo de IA, opcional)
OPENAI_API_KEY=sk-...

# JWT (si manejas auth propia además de Supabase Auth)
JWT_SECRET=cambia-esta-clave
