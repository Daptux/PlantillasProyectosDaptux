{
  "info": {
    "name": "clinica-app API",
    "description": "Coleccion de prueba - entrega 1 (auth + rutas protegidas)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Login (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json().data;",
              "if (data && data.token) { pm.collectionVariables.set('token', data.token); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@clinica.com\",\n  \"password\": \"Admin123*\"\n}"
        }
      }
    },
    {
      "name": "Register patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register-patient",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombres\": \"Ana\",\n  \"apellidos\": \"Lopez\",\n  \"email\": \"ana@test.com\",\n  \"password\": \"Ana12345\",\n  \"numero_documento\": \"5556667778\",\n  \"telefono\": \"+57 3001112233\"\n}"
        }
      }
    },
    {
      "name": "Me (protegido)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Users (requiere rol admin)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users"
      }
    }
  ]
}
