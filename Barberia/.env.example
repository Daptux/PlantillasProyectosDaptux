# ─────────────────────────────────────────────────────────────
# BarberPro Studio — Variables de entorno
# Copia este archivo como .env.local y completa los valores.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave anonima (publica) — segura para usar en el cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clave service role — SOLO servidor. NUNCA la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL publica del sitio (para redirects de auth, emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ID de la barberia activa para esta instancia de la plantilla.
# Debe coincidir con el id sembrado en supabase/seed.sql
NEXT_PUBLIC_BARBERIA_ID=00000000-0000-0000-0000-000000000001
